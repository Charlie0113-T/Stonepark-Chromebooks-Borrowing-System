# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default – no extra config needed):
#   DB_PATH=./data/chromebook.db

# PostgreSQL (replace SQLite with pg driver in src/db/database.js):
#   DATABASE_URL=postgresql://user:password@localhost:5432/chromebook_db

DB_PATH=./data/chromebook.db
DATABASE_URL=

# ── Authentication ────────────────────────────────────────────────────────────
# JWT secret – use a long random string in production
JWT_SECRET=change-this-to-a-secure-random-string

# Set to 'true' to skip auth entirely in local development
AUTH_BYPASS=true

# Seed whitelist emails (comma-separated). If not set, uses 4 defaults.
WHITELIST_SEED=chta0655@cloud.edu.pe.ca,placeholder-admin-1@cloud.edu.pe.ca,placeholder-admin-2@cloud.edu.pe.ca,placeholder-admin-3@cloud.edu.pe.ca

# Admin accounts to seed (comma-separated email:password pairs). Admins are always whitelisted.
ADMIN_USERS=chta0655@cloud.edu.pe.ca:6gLoVE21@

# Comma-separated allowed origins for CORS. Leave empty in local development.
# Example: CORS_ORIGIN=https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGIN=

# Google OAuth 2.0 (optional – enables /api/auth/google)
#   1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add http://localhost:4000/api/auth/google/callback as a redirect URI
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# URL of the frontend (used to redirect after OAuth callback)
FRONTEND_URL=http://localhost:3000

# ── Email Notifications (Nodemailer) ──────────────────────────────────────────
# Leave blank to disable email notifications.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# NOTIFY_FROM=Chromebook Manager <your-email@gmail.com>
# NOTIFY_TO=admin@stonepark.school.nz
# NOTIFY_CC=

# ── Google Chat Webhook ───────────────────────────────────────────────────────
# Leave blank to disable Google Chat notifications.
# GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...
